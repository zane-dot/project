# Database
DATABASE_URL="postgresql://finance_user:finance_pass@localhost:5432/finance_tracker"

# JWT
JWT_SECRET="change_this_to_a_strong_random_secret_at_least_32_chars"
JWT_EXPIRES_IN="7d"

# OpenAI (optional — when missing, AI endpoint returns a rule-based fallback)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Server
PORT=3000
NODE_ENV=development

# CORS — comma separated list of allowed origins
CORS_ORIGIN="http://localhost:5173"
